				</div>

				<button type="button" class="ff-btn ff-btn--secondary" onclick={() => (drawerOpen = false)}>
					✕
				</button>
			</div>

			<nav class="mt-6 grid gap-2">
				<button
					type="button"
					class="ff-btn ff-btn--secondary"
					onclick={() => {
						drawerOpen = false;
						goto('/platform');
					}}
				>
					Back to platform
				</button>

				<button
					type="button"
					class="ff-btn ff-btn--secondary"
					onclick={() => {
						drawerOpen = false;
						goto('/platform/onboarding');
					}}
				>
					Onboarding
				</button>

				<button
					type="button"
					class="ff-btn ff-btn--secondary"
					onclick={() => {
						drawerOpen = false;
						goto(publicPath);
					}}
				>
					Live fundraiser
				</button>

				<button
					type="button"
					class="ff-btn ff-btn--primary"
					onclick={() => {
						drawerOpen = false;
						dataMode = dataMode === 'preview' ? 'live' : 'preview';
					}}
				>
					{dataMode === 'preview' ? 'Publish setup' : 'Set preview'}
				</button>
			</nav>
		</aside>
	{/if}

	<main id="content" class="mx-auto max-w-7xl px-3 pt-5 pb-16">
		<section class="grid gap-4 xl:grid-cols-[1.14fr_0.86fr]">
			<article class="ff-card ff-card--shell p-5 md:p-7">
				<div class="flex flex-wrap items-start justify-between gap-4">
					<div class="max-w-4xl">
						<p class="ff-kicker">Workspace status</p>

						<h1
							class="mt-4 max-w-[10ch] text-5xl leading-[0.92] font-black tracking-[-0.06em] text-white md:text-7xl"
						>
							Operate the fundraiser from one calmer view.
						</h1>

						<p class="mt-4 max-w-3xl text-base leading-7 text-slate-200">
							Track launch readiness, campaign progress, sponsor support, and next actions without
							jumping between scattered tools.
						</p>
					</div>

					<span class={badgeClass(dataMode === 'preview' ? 'warn' : 'good')}>
						{dataMode === 'preview' ? 'Preview mode' : 'Live mode'}
					</span>
				</div>

				<div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
					{#each metrics as item (item.label)}
						<div class="ff-card ff-card--soft">
							<p class="ff-kicker">{item.label}</p>
							<p class="ff-metricValue">{item.value}</p>
							<p class="mt-2 text-sm leading-6 text-slate-200">{item.note}</p>
						</div>
					{/each}
				</div>

				<div class="mt-5 grid gap-3 md:grid-cols-3">
					{#each actions as item (item.title)}
						<div class="ff-card ff-card--soft">
							<p class="text-xl font-black tracking-[-0.03em] text-white">{item.title}</p>
							<p class="mt-2 text-sm leading-6 text-slate-200">{item.body}</p>
							<div class="mt-4">
								<button
									type="button"
									class={item.primary ? 'ff-btn ff-btn--primary' : 'ff-btn ff-btn--secondary'}
									onclick={item.action}
								>
									{item.cta}
								</button>
							</div>
						</div>
					{/each}
				</div>

				{#if copyNotice}
					<div class="ff-alert ff-alert--info mt-5">
						{copyNotice}
					</div>
				{/if}
			</article>

			<aside class="ff-card ff-card--shell self-start p-5 md:p-7 xl:sticky xl:top-24">
				<p class="ff-kicker">Launch diagnostics</p>

				<h2 class="mt-4 text-4xl leading-[1.02] font-black tracking-[-0.04em] text-white">
					Keep the product honest.
				</h2>

				<p class="mt-3 text-sm leading-7 text-slate-200">
					Know what mode the workspace is in, what is ready, and what still needs wiring before this
					becomes a real public launch.
				</p>

				<div class="mt-5 grid gap-3">
					{#each diagnostics as item (item.label)}
						<div class="ff-card ff-card--soft flex items-center justify-between gap-3">
							<div>
								<p class="ff-kicker">{item.label}</p>
								<p class="mt-2 text-sm font-semibold text-white">{item.value}</p>
							</div>

							<span class={badgeClass(item.tone)}>
								{item.tone === 'good' ? 'Ready' : item.tone === 'warn' ? 'Attention' : 'Info'}
							</span>
						</div>
					{/each}
				</div>

				<div class="mt-5 grid gap-3">
					<button type="button" class="ff-btn ff-btn--primary" onclick={copyPublicLink}>
						Copy public link
					</button>

					<button type="button" class="ff-btn ff-btn--secondary" onclick={() => goto(publicPath)}>
						Open live fundraiser
					</button>

					<button
