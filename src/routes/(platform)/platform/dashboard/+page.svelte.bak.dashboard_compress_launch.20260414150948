<script lang="ts">
	import { browser } from '$app/environment';
	import { goto } from '$app/navigation';
	import { onMount } from 'svelte';
	import { mountFFPage, toggleFFTheme } from '$lib/utils/ff-theme';
	import { loadLaunchState, saveLaunchState, slugifyOrgName } from '$lib/config/ff-launch-state';

	type Metric = {
		label: string;
		value: string;
		note: string;
	};

	type Action = {
		title: string;
		body: string;
		cta: string;
		action: () => void;
		primary?: boolean;
	};

	type Activity = {
		title: string;
		meta: string;
		body: string;
	};

	type Diagnostic = {
		label: string;
		value: string;
		tone?: 'good' | 'warn' | 'muted';
	};

	const launch = loadLaunchState();

	let drawerOpen = $state(false);
	let copyNotice = $state('');
	let theme = $state<'dark' | 'light'>('dark');

	let orgName = $state(launch.orgName);
	let fundraisingGoal = $state(launch.fundraisingGoal);
	let sponsorLane = $state(launch.sponsorLane);
	let recurringLane = $state(launch.recurringLane);
	let paymentsConnected = $state(launch.paymentsConnected);
	let dataMode = $state<'preview' | 'live'>(launch.dataMode);

	const publicPath = $derived(`/c/${slugifyOrgName(orgName)}`);
	const publicUrl = $derived(
		browser ? `${window.location.origin}${publicPath}` : `https://getfuturefunded.com${publicPath}`
	);

	const raised = 5175;
	const donors = 73;
	const goal = $derived(Number(fundraisingGoal || '0'));
	const progress = $derived(goal > 0 ? Math.round((raised / goal) * 100) : 0);

	const metrics = $derived<Metric[]>([
		{
			label: 'Raised',
			value: `$${raised.toLocaleString()}`,
			note: 'Momentum is already building.'
		},
		{ label: 'Goal', value: `$${goal.toLocaleString()}`, note: 'Clear season target for launch.' },
		{ label: 'Progress', value: `${progress}%`, note: 'Public fundraising surface is active.' },
		{ label: 'Donors', value: `${donors}`, note: 'Community support is showing up.' }
	]);

	const activities: Activity[] = [
		{
			title: 'Fundraiser surface is live in preview mode',
			meta: 'Today • Public page',
			body: 'The campaign page is rendering, sponsor lanes are visible, and the donor journey is ready for payment wiring.'
		},
		{
			title: 'Onboarding workspace was updated',
			meta: 'Today • Operator flow',
			body: 'Organization setup, campaign basics, brand controls, and preview routing are now connected into one launch path.'
		},
		{
			title: 'Platform landing page is aligned',
			meta: 'Today • Marketing surface',
			body: 'The platform page now feels like the right software-first companion to the fundraiser.'
		}
	];

	const sponsorDiagnostics = $derived([
		{ label: 'Sponsor packages', value: sponsorLane ? 'Enabled' : 'Disabled' },
		{ label: 'Lead capture', value: sponsorLane ? 'UI ready' : 'Hidden' },
		{ label: 'Featured tier', value: sponsorLane ? '$500' : 'Off' },
		{ label: 'Recurring lane', value: recurringLane ? 'Enabled' : 'Off' }
	]);

	const actions = $derived<Action[]>([
		{
			title: 'Open live preview',
			body: 'Jump straight to the public page and review the supporter-facing experience.',
			cta: 'Preview live page',
			action: () => goto(publicPath),
			primary: true
		},
		{
			title: 'Return to setup',
			body: 'Update organization details, story, branding, or revenue lanes before launch.',
			cta: 'Update setup',
			action: () => goto('/platform/onboarding')
		},
		{
			title: dataMode === 'preview' ? 'Publish setup' : 'Set back to preview',
			body:
				dataMode === 'preview'
					? 'Mark the workspace as live once the public surface and payments are ready.'
					: 'Switch back into preview mode for additional setup changes.',
			cta: dataMode === 'preview' ? 'Go live' : 'Set preview',
			action: () => {
				dataMode = dataMode === 'preview' ? 'live' : 'preview';
			}
		}
	]);

	const diagnostics = $derived<Diagnostic[]>([
		{ label: 'Environment', value: 'local', tone: 'muted' },
		{
			label: 'Data mode',
			value: dataMode === 'preview' ? 'Preview' : 'Live',
			tone: dataMode === 'preview' ? 'warn' : 'good'
		},
		{
			label: 'Payments',
			value: paymentsConnected ? 'Connected' : 'Not connected',
			tone: paymentsConnected ? 'good' : 'warn'
		},
		{ label: 'Build lane', value: 'wave-4-scroll-compression', tone: 'muted' },
		{ label: 'Public route', value: publicPath, tone: 'muted' }
	]);

	function badgeClass(tone?: 'good' | 'warn' | 'muted') {
		if (tone === 'good') return 'ff-pill ff-pill--soft';
		if (tone === 'warn') return 'ff-pill ff-pill--accent';
		return 'ff-pill ff-pill--ghost';
	}

	function toggleTheme() {
		theme = toggleFFTheme(theme, {
			page: 'dashboard',
			template: 'platform',
			brand: 'connect-atx-elite',
			themePreset: 'core',
			dataMode
		});
	}

	async function copyPublicLink() {
		if (!browser || !navigator.clipboard) {
			copyNotice = 'Clipboard not available in this environment.';
			return;
		}

		await navigator.clipboard.writeText(publicUrl);
		copyNotice = 'Public fundraiser link copied.';
	}

	$effect(() => {
		saveLaunchState({
			...loadLaunchState(),
			orgName,
			fundraisingGoal,
			sponsorLane,
			recurringLane,
			paymentsConnected,
			dataMode,
			updatedAt: new Date().toISOString()
		});
	});

	onMount(() => {
		theme = mountFFPage('dashboard', {
			brand: 'connect-atx-elite',
			themePreset: 'core',
			dataMode: 'preview'
		});
	});
</script>

<svelte:head>
	<title>FutureFunded Dashboard</title>
	<meta
		name="description"
		content="Operator dashboard for launch status, campaign summary, sponsor readiness, and workspace controls."
	/>
</svelte:head>

<div class="ff-dashboardPage">
	<div class="ff-dashboardPage__inner">
	<a
		href="#content"
		class="ff-skip"
	>
		Skip to content
	</a>

	<header class="ff-appbar">
		<div class="ff-container">
			<div class="ff-appbar__inner">
				<div class="ff-dashboardTopbar">
					<div class="ff-brand ff-minw-0">
						<div class="ff-brand__mark">
							FF
						</div>

						<div class="ff-brand__meta ff-minw-0">
							<p class="ff-brand__title">FutureFunded</p>
							<p class="ff-dashboardMeta">Operator dashboard</p>
						</div>

						<span class="ff-pill ff-pill--ghost">Dashboard</span>
					</div>

					<nav class="ff-actions ff-desktopOnly">
						<button
							type="button"
							class="ff-btn ff-btn--secondary"
							onclick={() => goto('/platform')}
						>
							Back to platform
						</button>

						<button
							type="button"
							class="ff-btn ff-btn--secondary"
							onclick={() => goto('/platform/onboarding')}
						>
							Onboarding
						</button>

						<button type="button" class="ff-btn ff-btn--secondary" onclick={() => goto(publicPath)}>
							Live fundraiser
						</button>

						<button
							type="button"
							class="ff-btn ff-btn--secondary ff-themeToggle"
							aria-label="Toggle color theme"
							aria-pressed={theme === 'light'}
							onclick={toggleTheme}
						>
							<span class="ff-themeToggle__glyph" aria-hidden="true">◐</span>
							<span class="ff-themeToggle__label">Theme</span>
						</button>

						<button
							type="button"
							class="ff-btn ff-btn--primary"
							onclick={() => (dataMode = dataMode === 'preview' ? 'live' : 'preview')}
						>
							{dataMode === 'preview' ? 'Publish setup' : 'Set preview'}
						</button>
					</nav>

					<div class="ff-actions ff-mobileOnly">
						<button
							type="button"
							class="ff-btn ff-btn--secondary ff-themeToggle"
							aria-label="Toggle color theme"
							aria-pressed={theme === 'light'}
							onclick={toggleTheme}
						>
							<span class="ff-themeToggle__glyph" aria-hidden="true">◐</span>
						</button>

						<button
							type="button"
							class="ff-btn ff-btn--primary"
							onclick={() => (dataMode = dataMode === 'preview' ? 'live' : 'preview')}
						>
							{dataMode === 'preview' ? 'Publish' : 'Preview'}
						</button>

						<button
							type="button"
							class="ff-btn ff-btn--secondary"
							onclick={() => (drawerOpen = true)}
						>
							☰
						</button>
					</div>
				</div>
			</div>
		</div>
	</header>

	{#if drawerOpen}
		<button
			type="button"
			class="ff-drawer"
			aria-label="Close menu"
			onclick={() => (drawerOpen = false)}
		></button>

		<aside class="ff-drawer__panel ff-dashboardDrawer">
			<div class="flex items-center justify-between">
				<div>
					<p class="text-sm font-semibold">FutureFunded</p>
					<p class="ff-dashboardDrawerLabel">Dashboard</p>
				</div>

				<button type="button" class="ff-btn ff-btn--secondary" onclick={() => (drawerOpen = false)}>
					✕
				</button>
			</div>

			<nav class="mt-6 grid gap-2">
				<button
					type="button"
					class="ff-btn ff-btn--secondary"
					onclick={() => {
						drawerOpen = false;
						goto('/platform');
					}}
				>
					Back to platform
				</button>

				<button
					type="button"
					class="ff-btn ff-btn--secondary"
					onclick={() => {
						drawerOpen = false;
						goto('/platform/onboarding');
					}}
				>
					Onboarding
				</button>

				<button
					type="button"
					class="ff-btn ff-btn--secondary"
					onclick={() => {
						drawerOpen = false;
						goto(publicPath);
					}}
				>
					Live fundraiser
				</button>

				<button
					type="button"
					class="ff-btn ff-btn--secondary ff-themeToggle"
					aria-label="Toggle color theme"
					aria-pressed={theme === 'light'}
					onclick={() => {
						toggleTheme();
					}}
				>
					<span class="ff-themeToggle__glyph" aria-hidden="true">◐</span>
					<span class="ff-themeToggle__label">Theme</span>
				</button>

				<button
					type="button"
					class="ff-btn ff-btn--primary"
					onclick={() => {
						drawerOpen = false;
						dataMode = dataMode === 'preview' ? 'live' : 'preview';
					}}
				>
					{dataMode === 'preview' ? 'Publish setup' : 'Set preview'}
				</button>
			</nav>
		</aside>
	{/if}

	<main id="content" class="ff-main">
		<div class="ff-container">
		<section class="ff-section">
			<div class="ff-heroGrid">
			<article class="ff-card ff-dashboardHero">
				<div class="flex flex-wrap items-start justify-between gap-4">
					<div class="max-w-4xl">
						<p class="ff-kicker">Workspace status</p>

						<h1
							class="ff-display ff-mt-4 ff-dashboardTitle"
						>
							Operate the fundraiser from one calmer view.
						</h1>

						<p class="ff-lead ff-mt-4">
							Track launch readiness, campaign progress, sponsor support, and next actions without
							jumping between scattered tools.
						</p>
					</div>

					<span class={badgeClass(dataMode === 'preview' ? 'warn' : 'good')}>
						{dataMode === 'preview' ? 'Preview mode' : 'Live mode'}
					</span>
				</div>

				<div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
					{#each metrics as item (item.label)}
						<div class="ff-card ff-card--soft">
							<p class="ff-kicker">{item.label}</p>
							<p class="ff-metricValue">{item.value}</p>
							<p class="ff-dashboardBody ff-dashboardBody--sm ff-mt-2">{item.note}</p>
						</div>
					{/each}
				</div>

				<div class="mt-5 grid gap-3 md:grid-cols-3">
					{#each actions as item (item.title)}
						<div class="ff-card ff-card--soft">
							<p class="ff-h3">{item.title}</p>
							<p class="ff-dashboardBody ff-dashboardBody--sm ff-mt-2">{item.body}</p>
							<div class="mt-4">
								<button
									type="button"
									class={item.primary ? 'ff-btn ff-btn--primary' : item.title === 'Return to setup' ? 'ff-btn ff-btn--ghost' : 'ff-btn ff-btn--secondary'}
									onclick={item.action}
								>
									{item.cta}
								</button>
							</div>
						</div>
					{/each}
				</div>

				{#if copyNotice}
					<div class="ff-alert ff-alert--info mt-5">
						{copyNotice}
					</div>
				{/if}
			</article>

			<aside class="ff-card ff-dashboardRail xl:sticky xl:top-24">
				<p class="ff-kicker">Launch diagnostics</p>

				<h2 class="ff-h2 ff-mt-4">
					Keep the product honest.
				</h2>

				<p class="ff-copy ff-mt-3">
					Know what mode the workspace is in, what is ready, and what still needs wiring before this
					becomes a real public launch.
				</p>

				<div class="mt-5 grid gap-3">
					{#each diagnostics as item (item.label)}
						<div class="ff-card ff-card--soft flex items-center justify-between gap-3">
							<div>
								<p class="ff-kicker">{item.label}</p>
								<p class="ff-dashboardBody ff-mt-2">{item.value}</p>
							</div>

							<span class={badgeClass(item.tone)}>
								{item.tone === 'good' ? 'Ready' : item.tone === 'warn' ? 'Attention' : 'Info'}
							</span>
						</div>
					{/each}
				</div>

				<div class="mt-5 grid gap-3">
					<button type="button" class="ff-btn ff-btn--primary" onclick={copyPublicLink}>
						Copy fundraiser link
					</button>

					<button type="button" class="ff-btn ff-btn--secondary" onclick={() => goto(publicPath)}>
						Open public page
					</button>

					<button
						type="button"
						class="ff-btn ff-btn--ghost"
						onclick={() => goto('/platform/onboarding')}
					>
						Update setup
					</button>
				</div>
			</aside>
			</div>
		</section>

		<section class="ff-section ff-dashboardSectionWrap">
			<div class="grid gap-4 xl:grid-cols-[1fr_0.8fr]">
				<article class="ff-card ff-dashboardHero">
					<div class="flex flex-wrap items-end justify-between gap-4">
						<div class="max-w-3xl">
							<p class="ff-kicker">Recent activity</p>
							<h2
								class="ff-h2 ff-mt-3 ff-dashboardSectionTitle"
							>
								What changed across the launch flow.
							</h2>
						</div>

						<span class="ff-pill ff-pill--ghost">Today</span>
					</div>

					<div class="mt-5 grid gap-3">
						{#each activities as item (item.title)}
							<article class="ff-card ff-card--soft">
								<div class="flex flex-wrap items-center justify-between gap-2">
									<p class="ff-h3">{item.title}</p>
									<span class="ff-pill ff-pill--ghost">{item.meta}</span>
								</div>

								<p class="ff-copy ff-mt-3">{item.body}</p>
							</article>
						{/each}
					</div>
				</article>

				<aside class="ff-card ff-dashboardSection">
					<p class="ff-kicker">Sponsor lane</p>

					<h2
						class="ff-h2 ff-mt-3 ff-dashboardSectionTitle"
					>
						Sponsor readiness at a glance.
					</h2>

					<p class="ff-copy ff-mt-3">
						Keep the business-facing side of the fundraiser visible inside the operator workspace.
					</p>

					<div class="mt-5 grid gap-3 sm:grid-cols-2">
						{#each sponsorDiagnostics as item (item.label)}
							<div class="ff-card ff-card--soft">
								<p class="ff-kicker">{item.label}</p>
								<p class="ff-dashboardMetricValue">{item.value}</p>
							</div>
						{/each}
					</div>

					<div class="mt-5 grid gap-3">
						<button
							type="button"
							class="ff-btn ff-btn--primary"
							onclick={() => goto(publicPath + '#sponsors')}
						>
							Review sponsor packages
						</button>

						<button
							type="button"
							class="ff-btn ff-btn--secondary"
							onclick={() => goto('/platform/pricing')}
						>
							See pricing details
						</button>
					</div>
				</aside>
			</div>
		</section>

		<footer class="ff-section ff-dashboardFooterWrap">
			<div class="ff-card ff-dashboardFooter">
				<div class="grid gap-5 lg:grid-cols-[1fr_auto] lg:items-end">
					<div class="max-w-3xl">
						<p class="ff-kicker">Operator close</p>

						<h2
							class="ff-h2 ff-mt-3 ff-dashboardSectionTitle"
						>
							Keep the launch flow sharp.
						</h2>

						<p class="ff-copy ff-mt-4">
							Review the public surface, keep the workspace current, and move from preview to live
							when the fundraiser is ready.
						</p>
					</div>

					<div class="grid gap-3">
						<button type="button" class="ff-btn ff-btn--primary" onclick={() => goto(publicPath)}>
							Open public page
						</button>

						<button
							type="button"
							class="ff-btn ff-btn--ghost"
							onclick={() => goto('/platform/onboarding')}
						>
							Return to setup
						</button>
					</div>
				</div>
			</div>
		</footer>
			</div>
	</main>
	</div>
