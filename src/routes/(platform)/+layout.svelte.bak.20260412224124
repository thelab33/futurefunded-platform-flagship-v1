<script lang="ts">
  import { onMount } from 'svelte';
  import type { Snippet } from 'svelte';
  import { syncFFTheme, type FFTheme } from '$lib/utils/ff-theme';

  type Props = {
    children: Snippet;
  };

  let { children }: Props = $props();

  let theme = $state<FFTheme>('dark');

  onMount(() => {
    theme = syncFFTheme({
      template: 'platform',
      brand: 'connect-atx-elite',
      themePreset: 'core',
      dataMode: 'preview'
    });
  });
</script>

<div class="ff-page ff-shell" data-ff-surface="platform">
  <div class="ff-shellBg" aria-hidden="true"></div>
  {@render children()}
</div>
